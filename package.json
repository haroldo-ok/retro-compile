{
  "name": "retro-compile",
  "version": "0.2.0",
  "description": "In-browser compiler toolchain for retro platforms (NES, Game Boy, C64, and more)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "scripts", "README.md", "CHANGELOG.md", "CONTRIBUTING.md"],
  "scripts": {
    "build":          "tsc && node scripts/build-worker.mjs",
    "typecheck":      "tsc --noEmit",
    "test":           "node test/integration.test.mjs",
    "bundle:vendor":  "node scripts/bundle-vendor-node.mjs",
    "copy:assets":    "node scripts/copy-assets.mjs",
    "demo":           "npx serve . -p 4321",
    "build:all":      "npm run build && npm run bundle:vendor && npm run copy:assets"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "@types/node": "^22.0.0"
  },
  "keywords": ["retro","compiler","gameboy","nes","c64","z80","6502","wasm","emscripten"],
  "license": "MIT"
}
