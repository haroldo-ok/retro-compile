{
  "name": "retro-compile",
  "version": "0.1.0",
  "description": "In-browser compiler toolchain for retro platforms (NES, Game Boy, C64, and more)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types":   "./dist/index.d.ts"
    },
    "./worker": {
      "import": "./dist/worker.js"
    }
  },
  "files": ["dist", "scripts", "README.md"],
  "scripts": {
    "build":          "node build.mjs",
    "typecheck":      "tsc --noEmit",
    "test":           "node test/integration.test.mjs",
    "build:vendor":   "node scripts/build-vendor.mjs",
    "copy:assets":    "node scripts/copy-assets.mjs",
    "demo":           "npx serve . -p 4321"
  },
  "devDependencies": {
    "esbuild":    "^0.25.0",
    "typescript": "^5.9.2",
    "@types/node": "^22.0.0"
  },
  "keywords": ["retro","compiler","gameboy","nes","c64","z80","6502","wasm","emscripten"],
  "license": "MIT"
}
